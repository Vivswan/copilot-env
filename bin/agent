#!/bin/sh
# Single self-bootstrapping entry point (Linux + macOS) for copilot-env.
# Installs bun if missing, installs node_modules in-place in the checkout
# (`bun install`, whose postinstall floats the gateway), then execs the cli.ts
# dispatcher (start / stop / env / cost / codex_config / host_codex). The
# `agent` shell function (agents.bashrc) is what turns `agent env` output into
# shell state.
#
# No cache: node_modules lives directly in the checkout and cli.ts runs from
# there.
set -e
HERE="$(cd "$(dirname "$0")" && pwd)"
SNAP="$(cd "${HERE}/.." && pwd)"

if ! command -v bun >/dev/null 2>&1 && [ ! -x "$HOME/.bun/bin/bun" ]; then
    echo "==> Installing bun (one-time) ..." >&2
    curl -fsSL https://bun.sh/install | bash >/dev/null
fi
[ -x "$HOME/.bun/bin/bun" ] && PATH="$HOME/.bun/bin:$PATH"
export PATH

# Install node_modules in-place in the checkout. Scripts stay enabled so bun
# install's postinstall gateway float (src/gateway_float.ts) fires every call;
# HUSKY=0 keeps husky's `prepare` from reinstalling git hooks each time. Route
# all of bun's output to stderr so it can't leak into the `agent env` stdout the
# shell function evals.
( cd "${SNAP}" && HUSKY=0 bun install --frozen-lockfile >&2 )

exec bun run "${SNAP}/src/cli.ts" "$@"
