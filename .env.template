# copilot-env environment template
#
# Copy to .env for local defaults loaded from the checkout root by copilot-env.
# Already-set shell environment variables take precedence over .env values.

# --- Gateway float ---------------------------------------------------------

# Pin @jeffreycao/copilot-api to a specific version or dist-tag.
# When unset, copilot-env resolves the newest version within copilot-env.config
# bounds that satisfies bunfig.toml's install.minimumReleaseAge.
# COPILOT_API_VERSION=1.10.30

# Disable the gateway float entirely. Any non-empty value skips floating.
# COPILOT_API_NO_FLOAT=1

# --- Gateway runtime -------------------------------------------------------

# Base data directory for gateway config, state, logs, and usage DBs.
# Default: ~/.local/share/copilot-api
# COPILOT_API_HOME=/Users/you/.local/share/copilot-api

# First port to try when starting the local gateway.
# Default: 4141
# COPILOT_API_PORT_DEFAULT=4141

# Override the gateway entry file. Intended for tests/dev fakes.
# COPILOT_API_ENTRY=/absolute/path/to/copilot-api/dist/main.js

# Codex home to use for `agent setup-codex-config`.
# CODEX_HOME=/Users/you/.codex
