{
  "name": "copilot-env",
  "version": "3.3.16",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Local copilot-api proxy lifecycle + config helper (TypeScript port of the Python copilot-api helper).",
  "bin": {
    "agent": "./bin/agent"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 15000",
    "lint": "biome check src bin test scripts",
    "lint:sh": "bash scripts/lint-sh.sh",
    "lint:ps": "bash scripts/lint-ps.sh",
    "format": "biome format --write src bin test scripts",
    "check": "biome check --write src bin test scripts",
    "postinstall": "bun src/proxy_float.ts && bun node_modules/patch-package/index.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@jeffreycao/copilot-api": "latest",
    "commander": "^15.0.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "patch-package": "^8.0.0",
    "ps-list": "^9.0.0",
    "semver": "^7.8.2",
    "smol-toml": "^1.7.0",
    "tar": "^7.5.16",
    "valibot": "^1.4.1",
    "which": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "@types/which": "^3.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@biomejs/biome",
    "patch-package"
  ],
  "lint-staged": {
    "src/**/*.ts": "biome check --write --no-errors-on-unmatched",
    "test/**/*.ts": "biome check --write --no-errors-on-unmatched",
    "scripts/**/*.ts": "biome check --write --no-errors-on-unmatched",
    "bin/**/*": "biome check --write --no-errors-on-unmatched",
    "biome.json": "biome check --write --no-errors-on-unmatched"
  }
}
