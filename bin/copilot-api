#!/bin/sh
# Self-bootstrapping launcher (Linux + macOS). Installs bun if missing,
# runs cache_setup.ts (which symlinks src/ + manifest into the per-user
# cache and runs `bun install --frozen-lockfile` when the lockfile
# changes), then execs the TS entry from the cache.
set -e
HERE="$(cd "$(dirname "$0")" && pwd)"
SNAP="$(cd "${HERE}/.." && pwd)"

if ! command -v bun >/dev/null 2>&1 && [ ! -x "$HOME/.bun/bin/bun" ]; then
    echo "==> Installing bun (one-time) ..." >&2
    curl -fsSL https://bun.sh/install | bash >/dev/null
fi
[ -x "$HOME/.bun/bin/bun" ] && PATH="$HOME/.bun/bin:$PATH"
export PATH

BOOTSTRAP_COMMAND="${1:-}"
for arg in "$@"; do
    case "$arg" in
        --dry-run|-h|--help) BOOTSTRAP_COMMAND="" ;;
    esac
done

CACHE="$(bun run "${SNAP}/src/cache_setup.ts" "${SNAP}" "${BOOTSTRAP_COMMAND}")"
exec bun run "${CACHE}/src/server.ts" "$@"
