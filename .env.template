# copilot-env environment template
#
# Copy to .env for local defaults loaded from the checkout root by copilot-env.
# Already-set shell environment variables take precedence over .env values.

# --- Proxy float ---------------------------------------------------------

# Pin @jeffreycao/copilot-api to a specific version or dist-tag (bypasses the
# copilot-env.config floor/ceiling and the cooldown). When unset, copilot-env
# resolves the newest version within copilot-env.config bounds that satisfies the
# cooldown window. Use a version at or above PROXY_MIN_VERSION in copilot-env.config.
# COPILOT_API_VERSION=1.11.0

# Override the float cooldown window, in seconds (0 = no cooldown). Takes
# precedence over bunfig.toml's install.minimumReleaseAge.
# COPILOT_API_MIN_RELEASE_AGE=604800

# --- Proxy runtime -------------------------------------------------------

# Base data directory for proxy config, state, logs, and usage DBs.
# Default: ~/.local/share/copilot-api
# COPILOT_API_HOME=/Users/you/.local/share/copilot-api

# The default proxy port is now a config preference, not an env var:
#   agent config --set port 4141

# Override the proxy entry file. Intended for tests/dev fakes.
# COPILOT_API_ENTRY=/absolute/path/to/copilot-api/dist/main.js

# Codex home to use for `agent setup-codex-config`.
# CODEX_HOME=/Users/you/.codex
